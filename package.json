{
  "name": "webelieveacademics.com",
  "version": "1.0.0",
  "description": "Backend API and worker stack for We Believe Academics",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "education",
    "fastify",
    "postgresql",
    "redis",
    "anthropic"
  ],
  "author": "Codex",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/sensible": "^6.0.4",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.71.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.2",
    "ioredis": "^5.10.1",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "fastify-plugin": "^5.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
